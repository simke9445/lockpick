{
  "name": "@simke9445/lockpick",
  "version": "0.1.1",
  "description": "Standalone local advisory locking CLI and reusable TypeScript library.",
  "license": "MIT",
  "author": "Djordje Simovic",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "homepage": "https://github.com/simke9445/lockpick#readme",
  "bugs": {
    "url": "https://github.com/simke9445/lockpick/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simke9445/lockpick.git"
  },
  "keywords": [
    "advisory-lock",
    "multi-agent",
    "git",
    "cli",
    "bun",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lockpick": "bin/lockpick.ts"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun run typecheck",
    "lockpick": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "doctor": "bun run src/index.ts doctor",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run test && bun run typecheck && bun run lint"
  },
  "dependencies": {
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
